package ynsrvcs:plugins@0.1.0;

interface host {
    record response {
        status: u16,
        body: list<u8>,
    }

    http-request: func(method: string, url: string, body: list<u8>) -> result<response, string>;
    get-env: func(name: string) -> option<string>;
    gateway-ping: func() -> u64;
    now-ms: func() -> u64;
    log: func(level: string, message: string);
}

interface plugin {
    enum event-type {
        ready,
        message-create,
        interaction-create,
        guild-member-add,
        guild-member-remove,
        reaction-add,
        voice-state-update,
    }

    handle-event: func(event-type: event-type, payload: list<u8>, guild-id: u64, channel-id: u64);
}

world plugin-world {
    import host;
    export plugin;
}
